<% layout("/layouts/boilerplate") %>

<br>

    <form method="POST" action="/listings/<%=l._id%>?_method=PUT">
     <div class="row">
        <div class="col-8 offset-2">
            <h2>Edit Listing</h2>
            <div class="mb-3">
    <label for="title" class="form-label">Title</label>
    <input type="text" id="title" name="l[title]" value="<%= l.title %>" class="form-control">
</div>

<div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea id="description" name="l[description]" class="form-control"><%= l.description %></textarea>
</div>

<div class="mb-3">
    <label for="image" class="form-label">Image URL</label>
    <input type="text" id="image" name="l[image]" value="<%= l.image.url %>" class="form-control">
</div>

<div class="mb-3">
    <label for="price" class="form-label">Price</label>
    <input type="number" id="price" name="l[price]" value="<%= l.price %>" class="form-control">
</div>

<div class="mb-3">
    <label for="location" class="form-label">Location</label>
    <input type="text" id="location" name="l[location]" value="<%= l.location %>" class="form-control">
</div>

<div class="mb-3">
    <label for="country" class="form-label">Country</label>
    <input type="text" id="country" name="l[country]" value="<%= l.country %>" class="form-control">
</div>

<button class="btn btn-dark">Update</button>
        </div>
     </div>
    </form>
    <br><br>
    

